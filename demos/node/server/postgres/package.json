{
  "name": "@next-model-demos/postgres-node",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prestart": "pnpm --workspace-root run build:packages",
    "start": "node --experimental-strip-types demo.ts",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down -v"
  },
  "dependencies": {
    "@next-model/core": "workspace:*",
    "@next-model/postgres-connector": "workspace:*",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.6"
  }
}

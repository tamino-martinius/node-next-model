{
  "name": "next-model-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @next-model/core and its connector packages",
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-next-model.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/core' --filter './packages/knex-connector' --filter './packages/aurora-data-api-connector' --filter './packages/local-storage-connector' --filter './packages/migrations' --filter './packages/express-rest-api' --filter './packages/graphql-api' --filter './packages/nextjs-api' --filter './packages/migrations-generator' --filter './packages/zod' --filter './packages/typebox' --filter './packages/arktype' --filter './packages/react' run build",
    "build:packages": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/core' --filter './packages/aurora-data-api-connector' --filter './packages/local-storage-connector' --filter './packages/express-rest-api' --filter './packages/graphql-api' --filter './packages/nextjs-api' --filter './packages/migrations-generator' --filter './packages/zod' --filter './packages/typebox' --filter './packages/arktype' --filter './packages/react' run test",
    "test:all": "pnpm -r --filter './packages/core' --filter './packages/knex-connector' --filter './packages/aurora-data-api-connector' --filter './packages/local-storage-connector' --filter './packages/migrations' --filter './packages/express-rest-api' --filter './packages/graphql-api' --filter './packages/nextjs-api' --filter './packages/migrations-generator' --filter './packages/zod' --filter './packages/typebox' --filter './packages/arktype' --filter './packages/react' run test",
    "typecheck": "pnpm -r --filter './packages/core' --filter './packages/knex-connector' --filter './packages/aurora-data-api-connector' --filter './packages/local-storage-connector' --filter './packages/migrations' --filter './packages/express-rest-api' --filter './packages/graphql-api' --filter './packages/nextjs-api' --filter './packages/migrations-generator' --filter './packages/zod' --filter './packages/typebox' --filter './packages/arktype' --filter './packages/react' run typecheck",
    "typecheck:demos": "pnpm -r --filter '@next-model-demos/*' run typecheck",
    "lint": "biome check .",
    "test:release": "node --test .github/scripts/*.test.mjs",
    "format": "biome format --write .",
    "ci": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}

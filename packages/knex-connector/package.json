{
  "name": "@next-model/knex-connector",
  "version": "1.0.0-alpha.9",
  "description": "SQL connector for next-model package using Knex.",
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "jsnext:main": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-next-model-knex-connector.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "build": "rm -rf dist/* && tsc && tsc-mjs --declaration false --target esnext --module esnext --mjs",
    "preversion": "pnpm build && git add ."
  },
  "devDependencies": {
    "@next-model/core": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "sqlite3": "^6.0.1",
    "ts-mjs": "^3.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "knex": "^3.2.9"
  }
}

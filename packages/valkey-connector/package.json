{
  "name": "@next-model/valkey-connector",
  "version": "1.0.0-alpha.0",
  "description": "Valkey connector for next-model. Extends @next-model/redis-connector — Valkey is wire-compatible with Redis.",
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-next-model.git",
    "directory": "packages/valkey-connector"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@next-model/redis-connector": "workspace:*",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@next-model/core": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

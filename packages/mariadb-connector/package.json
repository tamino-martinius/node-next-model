{
  "name": "@next-model/mariadb-connector",
  "version": "1.0.0-rc.5",
  "description": "Native MariaDB connector for next-model. Extends @next-model/mysql-connector and uses MariaDB's RETURNING clause.",
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-next-model.git",
    "directory": "packages/mariadb-connector"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@next-model/mysql-connector": "workspace:*",
    "mysql2": "^3.22.3"
  },
  "devDependencies": {
    "@next-model/core": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

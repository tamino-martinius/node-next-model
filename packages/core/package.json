{
  "name": "@next-model/core",
  "version": "1.0.0-rc.1",
  "description": "AWS Data API model layer package with zero dependencies to use in lambda",
  "keywords": [
    "model",
    "database",
    "model layer",
    "pg",
    "postgres",
    "mysql",
    "data api",
    "dataapi",
    "aws",
    "serverless",
    "typescript",
    "node",
    "nodejs"
  ],
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__benchmark__",
    "!dist/**/*.map"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-data-api-model.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "build": "pnpm clean && tsc",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}

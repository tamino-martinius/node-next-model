{
  "name": "@next-model/core",
  "version": "1.0.0-alpha.31",
  "description": "AWS Data API model layer package with zero dependencies to use in lambda",
  "keywords": [
    "model",
    "database",
    "model layer",
    "pg",
    "postgres",
    "mysql",
    "data api",
    "dataapi",
    "aws",
    "serverless",
    "typescript",
    "node",
    "nodejs"
  ],
  "author": "Tamino Martinius <dev@zaku.eu>",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "jsnext:main": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-data-api-model.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "build": "rm -rf dist/* && tsc && tsc-mjs --declaration false --target esnext --module esnext --mjs",
    "preversion": "pnpm build && git add ."
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^2.1.3",
    "ts-mjs": "^3.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}

{
  "name": "@next-model/data-api-connector",
  "version": "1.0.0-alpha.3",
  "description": "Connector for AWS Aurora Data API.",
  "author": "Tamino Martinius <dev@zaku.eu>",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "jsnext:main": "./dist/index.mjs",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-next-model-data-api-connector.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -w",
    "build": "rm -rf dist/* && tsc && tsc-mjs --declaration false --target esnext --module esnext --mjs",
    "preversion": "pnpm build && git add ."
  },
  "devDependencies": {
    "@next-model/core": "workspace:*",
    "@types/knex": "^0.16.1",
    "@types/faker": "^4.1.5",
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^2.1.3",
    "faker": "^4.1.0",
    "ts-mjs": "^3.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "knex": "^0.19.4",
    "data-api-client": "^1.0.1"
  }
}
